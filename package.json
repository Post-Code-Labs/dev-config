{
  "name": "@builtbydoug/dev-config",
  "version": "0.0.0",
  "description": "Shared, importable baseline configs (Prettier, tsconfig, ESLint, ruff/mypy) for consuming repos. Released as CalVer git tags (YYYY.MM); the tag is the version contract, not this field.",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "test": "node --test"
  },
  "exports": {
    "./prettier": "./prettier/index.json",
    "./typescript/tsconfig.base.json": "./typescript/tsconfig.base.json",
    "./typescript/tsconfig.react.json": "./typescript/tsconfig.react.json",
    "./eslint/base": "./eslint/base.mjs",
    "./eslint/react": "./eslint/react.mjs",
    "./python/ruff.toml": "./python/ruff.toml",
    "./python/mypy.ini": "./python/mypy.ini",
    "./versions.json": "./versions.json"
  },
  "files": [
    "prettier",
    "typescript",
    "eslint",
    "python",
    "versions.json"
  ],
  "peerDependencies": {
    "eslint": "^10.4.0",
    "eslint-config-next": ">=16.2.7",
    "eslint-config-prettier": ">=10.1.0",
    "eslint-plugin-import-x": ">=4.16.0",
    "prettier": ">=3.8.0",
    "typescript": ">=6.0.0",
    "typescript-eslint": ">=8.60.0"
  },
  "peerDependenciesMeta": {
    "eslint-config-next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "eslint": "10.4.1",
    "eslint-config-next": "16.2.7",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import-x": "4.16.2",
    "next": "^16.2.7",
    "prettier": "3.8.3",
    "react": "^19.0.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1"
  }
}
